{
  "name": "reddit-clone-backend",
  "version": "1.0.0",
  "description": "Threadit Reddit Clone - Backend API",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "postinstall": "node node_modules/.bin/prisma generate",
    "db:generate": "node node_modules/.bin/prisma generate",
    "db:push": "node node_modules/.bin/prisma db push",
    "db:migrate": "node node_modules/.bin/prisma migrate dev",
    "db:seed": "node prisma/seed.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^5.7.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}